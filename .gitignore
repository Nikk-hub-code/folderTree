```gitignore
# ==========================================================
# Python
# ==========================================================

__pycache__/
*.py[cod]
*$py.class

# Compiled Extensions
*.so
*.pyd

# ==========================================================
# Virtual Environments
# ==========================================================

.venv/
venv/
env/
ENV/

# ==========================================================
# Build & Distribution
# ==========================================================

build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ==========================================================
# Python Cache
# ==========================================================

.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.tox/
.nox/

# ==========================================================
# Coverage Reports
# ==========================================================

.coverage
.coverage.*
htmlcov/

# ==========================================================
# IDEs & Editors
# ==========================================================

.vscode/
.idea/

# Vim
*.swp
*.swo

# ==========================================================
# Operating System Files
# ==========================================================

.DS_Store
Thumbs.db
desktop.ini

# ==========================================================
# Logs
# ==========================================================

*.log

# ==========================================================
# Environment Variables
# ==========================================================

.env
.env.*

# ==========================================================
# Generated Output
# ==========================================================

output/

# ==========================================================
# Temporary Files
# ==========================================================

*.tmp
*.temp
*.bak

# ==========================================================
# Project Ignore File
# ==========================================================

.foldertreeignore

# ==========================================================
# Jupyter
# ==========================================================

.ipynb_checkpoints/

# ==========================================================
# Miscellaneous
# ==========================================================

.cache/
```
